{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:test": "cross-env VITE_USE_FIREBASE_EMULATOR=true vite --port=5173 --host=127.0.0.1",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "emulator:start": "firebase emulators:start --only auth,firestore,database --project demo-couple-test",
    "emulator:exec": "firebase emulators:exec --only auth,firestore,database --project demo-couple-test 'echo Emulator ready'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.4.0",
    "firebase": "^12.15.0",
    "html2canvas": "^1.4.1",
    "lenis": "^1.3.25",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "swiper": "^14.0.5",
    "tailwind-merge": "^3.6.0",
    "tone": "^15.1.22",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "esbuild": "^0.25.0",
    "firebase-admin": "^13.0.0",
    "firebase-tools": "^14.0.0",
    "jsdom": "^25.0.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^2.1.9"
  }
}
