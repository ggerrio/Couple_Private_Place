# ==========================================================
# HOW TO USE
#   1. Copy this file to `.env` (exact same name, no extension).
#   2. Fill in the values for YOUR Firebase project + Cloudinary + YouTube.
#   3. The app throws a clear, actionable error at startup if any
#      REQUIRED key below is empty -- so if your app boots, all six
#      Firebase configs are valid.
# ==========================================================
#
# Optional keys (Cloudinary / YouTube / Admin email) can be left
# empty if you don't use the corresponding feature -- the code
# degrades gracefully.

# ---- Demo Mode ----
# Set VITE_DEMO_MODE=true to run the app without Firebase.
# The app uses sample data from defaults.ts + localStorage only.
# Perfect for GitHub Pages / public demo deployments.
# When false (or unset), Firebase is required as usual.
VITE_DEMO_MODE=false

# ---- Required: Firebase Configuration (only if VITE_DEMO_MODE=false) ----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# ---- Optional: Cloudinary (Photobooth uploads) ----
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ---- Optional: YouTube Data API (music search) ----
VITE_YOUTUBE_API_KEY=

# ---- Optional: Admin Google account (admin-only features) ----
VITE_ADMIN_EMAIL=
