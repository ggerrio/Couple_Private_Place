rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ────────── Helper functions ────────────────────────────────────────
    // Reads the admin email from the admin_config document in Firestore
    function getAdminEmail() {
      return get(/databases/$(database)/documents/settings/admin_config).data.admin_email;
    }

    // Returns true if the requester's email matches the stored admin email
    function isAdmin() {
      return request.auth != null && request.auth.token.email.toLowerCase() == getAdminEmail().toLowerCase();
    }

    // ────────── Admin config — can only be modified by the admin ────────
    match /settings/admin_config {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ────────── Profiles — users can update their own, admin can do all ─
    match /profiles/{profileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Allow update if:
      //   - user is admin, OR
      //   - the user owns this profile slot (auth_id matches), OR
      //   - user_a slot: the user's email matches the admin email, OR
      //   - user_b slot: the user's email is NOT the admin email (anyone else)
      allow update: if isAdmin()
        || request.auth.uid == resource.data.auth_id
        || (profileId == 'user_a' && request.auth.token.email.toLowerCase() == getAdminEmail().toLowerCase())
        || (profileId == 'user_b' && request.auth.token.email.toLowerCase() != getAdminEmail().toLowerCase());
      allow delete: if isAdmin();
    }

    // ────────── Everything else — any authenticated user can access ─────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
